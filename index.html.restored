        // ==================== 鏁版嵁鍚屾锛堜笌鍚庡彴瀹炴椂鑱斿姩锛?====================
        const syncChannel = new BroadcastChannel('procurement_sync');

        function countAllKeywords() {
            let t = 0;
            if (DATA && DATA.categories) {
                DATA.categories.forEach(c => {
                    if (c.subcategories) c.subcategories.forEach(s => {
                        if (s.keywords) t += s.keywords.length;
                    });
                });
            }
            return t;
        }

        function updateStats() {
            const els = document.querySelectorAll('.stat-item');
            if (els.length >= 1) els[0].innerHTML = countAllKeywords() + ' 鍏抽敭璇?;
        }

        function checkLocalSync() {
            const d = localStorage.getItem('keyword_database');
            if (d) {
                try {
                    const p = JSON.parse(d);
                    if (p.categories && p.categories.length > 0 && p._savedAt) {
                        const SAVE_AGE_MS = 30 * 60 * 1000;
                        if (Date.now() - p._savedAt < SAVE_AGE_MS) {
                            DATA = p;
                            console.log('[Sync] Using backend data v' + DATA.version);
                            if (typeof performSearch === 'function') performSearch();
                            return;
                        }
                    }
                } catch(e) {}
            }
            try { localStorage.removeItem('keyword_database'); } catch(e) {}
        }

        function showSyncNotification() {
            const n = document.getElementById('syncNotify');
            if (n) n.remove();
            const notify = document.createElement('div');
            notify.id = 'syncNotify';
            notify.style.cssText = 'position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#52c41a;color:#fff;padding:10px 24px;border-radius:25px;font-size:14px;z-index:9999;box-shadow:0 4px 15px rgba(82,196,26,0.4)';
            notify.textContent = '\u2705 鏁版嵁宸蹭粠鍚庡彴鍚屾';
            document.body.appendChild(notify);
            setTimeout(() => notify.remove(), 2500);
        }

        syncChannel.onmessage = function(e) {
            const m = e.data;
            console.log('[鍚屾] 鏀跺埌:', m.type);
            if (m.type === 'data_updated') {
                const d = localStorage.getItem('keyword_database');
                if (d) {
                    DATA = JSON.parse(d);
                    if (typeof performSearch === 'function') performSearch();
                    if (typeof updateStats === 'function') updateStats();
                }
            }
            if (m.type === 'purchase_updated') {
                purchaseData = null;
                const p = document.getElementById('purchasePanel');
                if (p && p.classList.contains('show')) {
                    if (typeof renderPurchaseCats === 'function') renderPurchaseCats();
                    if (typeof renderPurchaseProducts === 'function') renderPurchaseProducts(
                        typeof currentPurchaseCat !== 'undefined' ? currentPurchaseCat : 'all'
                    );
                }
            }
            showSyncNotification();
        };

        // 鍚姩鏃舵鏌ュ悗鍙板悓姝ユ暟鎹?
        checkLocalSync();

        let currentFilter = 'all';
        let currentSort = 'heat';
        let currentCategory = 'all';
        let allKeywords = [];
        
        function flattenKeywords() {
            const flat = [];
            DATA.categories.forEach(cat => {
                cat.subcategories.forEach(sub => {
                    sub.keywords.forEach(kw => {
                        flat.push({
                            ...kw,
                            category: cat.name,
                            categoryId: cat.id,
                            subcategory: sub.name
                        });
                    });
                });
            });
            return flat;
        }

        allKeywords = flattenKeywords();

        // ==================== 鐢ㄦ埛璁よ瘉绯荤粺 ====================
        const CURRENT_USER_KEY = 'procurement_current_user';

        // 妫€鏌ョ櫥褰曠姸鎬?
        function checkAuth() {
            const userJson = localStorage.getItem(CURRENT_USER_KEY);
            if (!userJson) {
                showAuthOverlay();
                return false;
            }

            const user = JSON.parse(userJson);
            
            // 妫€鏌ユ槸鍚﹁繃鏈?
            if (user.expires && new Date().getTime() > user.expires) {
                localStorage.removeItem(CURRENT_USER_KEY);
                showAuthOverlay();
                return false;
            }

            showUserBar(user);
            return true;
        }

        // 鏄剧ず鏈櫥褰曢伄缃?
        function showAuthOverlay() {
            document.getElementById('authOverlay').style.display = 'flex';
            document.getElementById('userBar').style.display = 'none';
        }

        // 鏄剧ず鐢ㄦ埛鐘舵€佹爮
        function showUserBar(user) {
            document.getElementById('authOverlay').style.display = 'none';
            document.getElementById('userBar').style.display = 'flex';
            
            const avatar = (user.nickname || user.username).charAt(0).toUpperCase();
            document.getElementById('userAvatar').textContent = avatar;
            document.getElementById('userName').textContent = user.nickname || user.username;
            
            const badge = document.getElementById('userBadge');
            badge.textContent = '宸茶璇?;
            badge.className = 'user-badge';
        }

        // 璺宠浆鍒扮櫥褰曢〉
        function goToLogin() {
            window.location.href = 'login.html';
        }

        // 璺宠浆鍒扮鐞嗗悗鍙?
        function goToAdmin() {
            window.location.href = 'admin.html';
        }

        // 閫€鍑虹櫥褰?
        async function logout() {
            const userJson = localStorage.getItem(CURRENT_USER_KEY);
            if (userJson) {
                const user = JSON.parse(userJson);
                // 璁板綍鐧诲嚭鏃ュ織
                await addLog('logout', user.username, '鐢ㄦ埛涓诲姩鐧诲嚭');
            }
            localStorage.removeItem(CURRENT_USER_KEY);
            window.location.href = 'login.html';
        }

        // 鑾峰彇瀹㈡埛绔疘P
        async function getClientIP() {
            try {
                const resp = await fetch('https://api.ipify.org?format=json');
                const data = await resp.json();
                return data.ip || '鏈煡';
            } catch(e) {
                return '鏈煡IP';
            }
        }

        // 娣诲姞鏃ュ織
        async function addLog(type, username, detail) {
            const logs = JSON.parse(localStorage.getItem('procurement_logs') || '[]');
            const ip = await getClientIP();
            logs.unshift({
                time: new Date().toLocaleString('zh-CN'),
                type: type,
                username: username,
                ip: ip,
                detail: detail
            });
            if (logs.length > 500) logs.pop();
            localStorage.setItem('procurement_logs', JSON.stringify(logs));
        }

        // 椤甸潰鍔犺浇鏃舵鏌ョ櫥褰曠姸鎬?
        checkAuth();

        document.getElementById('statCats').textContent = DATA.categories.length;
        document.getElementById('statSubs').textContent = DATA.categories.reduce((s,c) => s + c.subcategories.length, 0);
        document.getElementById('statKws').textContent = allKeywords.length;

        function renderCategories() {
            const grid = document.getElementById('categoriesGrid');
            let html = '<div class="category-card ' + (currentCategory === 'all' ? 'selected' : '') + '" data-category="all"><div class="category-name">鍏ㄩ儴鍝佺被</div><div class="category-count">' + allKeywords.length + ' 璇?/div></div>';

            DATA.categories.forEach(cat => {
                const count = cat.subcategories.reduce((sum, sub) => sum + sub.keywords.length, 0);
                html += '<div class="category-card ' + (currentCategory === cat.id ? 'selected' : '') + '" data-category="' + cat.id + '"><div class="category-name">' + cat.name.zh + '</div><div class="category-count">' + count + ' 璇?/div></div>';
            });

            grid.innerHTML = html;

            grid.querySelectorAll('.category-card').forEach(card => {
                card.addEventListener('click', () => {
                    currentCategory = card.dataset.category;
                    renderCategories();
                    performSearch();
                });
            });
        }

        function getHeatLabel(heat) {
            const labels = ['', '涓€鑸?, '涓?, '涓珮', '楂?, '瓒呴珮'];
            const icons = ['', '馃搲', '馃搳', '馃搱', '鈿?, '馃敟'];
            return icons[heat] + ' ' + labels[heat];
        }

        function renderKeywords(keywords) {
            const grid = document.getElementById('resultsGrid');
            const info = document.getElementById('resultsInfo');

            if (keywords.length === 0) {
                grid.innerHTML = '<div class="no-results"><h2>馃攳 鏈壘鍒扮浉鍏冲叧閿瘝</h2><p>灏濊瘯鎹釜鎼滅储璇嶆垨璋冩暣绛涢€夋潯浠?/p></div>';
                info.textContent = '鏈壘鍒扮粨鏋?;
                return;
            }

            info.textContent = '鎵惧埌 ' + keywords.length + ' 涓叧閿瘝';

            grid.innerHTML = keywords.slice(0, 30).map(kw => {
                const words = currentLang === 'en' ? kw.vw.en : kw.vw.zh;
                const attrs = currentLang === 'en' ? kw.aw.en : kw.aw.zh;
                const scenes = currentLang === 'en' ? kw.sw.en : kw.sw.zh;

                return '<div class="keyword-card heat-' + kw.h + '">' +
                    '<div class="keyword-header">' +
                        '<div class="keyword-title-group">' +
                            '<div class="keyword-title">' + kw.pw.zh + '</div>' +
                            '<div class="keyword-title-en">' + kw.pw.en + '</div>' +
                        '</div>' +
                        '<div class="keyword-actions">' +
                            '<button class="copy-btn" onclick="copyKeyword(\'' + kw.pw.zh + '\', \'' + kw.pw.en + '\')">馃搵 澶嶅埗</button>' +
                            '<span class="heat-badge">' + getHeatLabel(kw.h) + '</span>' +
                        '</div>' +
                    '</div>' +
                    '<div class="keyword-section">' +
                        '<div class="section-title">馃彿锔?鍝佺被</div>' +
                        '<div class="word-tags">' +
                            '<span class="word-tag">' + kw.category.zh + '</span>' +
                            '<span class="word-tag">' + kw.subcategory.zh + '</span>' +
                        '</div>' +
                    '</div>' +
                    '<div class="keyword-section">' +
                        '<div class="section-title">馃攧 鍙樹綋璇?/div>' +
                        '<div class="word-tags">' +
                            words.slice(0, 4).map(w => '<span class="word-tag" onclick="copyText(\'' + w + '\')">' + w + '</span>').join('') +
                        '</div>' +
                    '</div>' +
                    '<div class="keyword-section">' +
                        '<div class="section-title">鈿欙笍 灞炴€ц瘝</div>' +
                        '<div class="word-tags">' +
                            attrs.slice(0, 3).map(w => '<span class="word-tag" onclick="copyText(\'' + w + '\')">' + w + '</span>').join('') +
                        '</div>' +
                    '</div>' +
                    '<div class="keyword-section">' +
                        '<div class="section-title">馃幆 鍦烘櫙璇?/div>' +
                        '<div class="word-tags">' +
                            scenes.slice(0, 3).map(w => '<span class="word-tag" onclick="copyText(\'' + w + '\')">' + w + '</span>').join('') +
                        '</div>' +
                    '</div>' +
                    (kw.notes ? '<div class="keyword-note">馃挕 ' + kw.notes + '</div>' : '') +
                    '<div class="platform-links">' +
                        '<a href="https://s.1688.com/selloffer/offer_search.htm?keywords=' + kw.pw_gbk + '" target="_blank" class="platform-btn platform-1688">1688</a>' +
                        '<a href="https://www.alibaba.com/trade/search?SearchText=' + encodeURIComponent(kw.pw.en) + '" target="_blank" class="platform-btn platform-alibaba">Alibaba</a>' +
                        '<a href="https://www.made-in-china.com/products-search/hot-china-products/' + kw.pw.en.replace(/ /g, '_') + '.html" target="_blank" class="platform-btn platform-mic">Made-in-China</a>' +
                    '</div>' +
                '</div>';
            }).join('');
        }

        function performSearch() {
            const query = document.getElementById('searchInput').value.trim().toLowerCase();
            let results = allKeywords;

            // 鍝佺被绛涢€?
            if (currentCategory !== 'all') {
                results = results.filter(kw => kw.categoryId === currentCategory);
            }

            // 鐑害绛涢€?
            if (currentFilter !== 'all') {
                const heatLevel = parseInt(currentFilter);
                results = results.filter(kw => kw.h >= heatLevel);
            }

            // 鍏抽敭璇嶆悳绱?
            if (query) {
                results = results.filter(kw => {
                    const searchText = (kw.pw.zh + ' ' + kw.pw.en + ' ' + kw.vw.zh.join(' ') + ' ' + kw.vw.en.join(' ')).toLowerCase();
                    return searchText.includes(query);
                });
            }

            // 鎺掑簭
            if (currentSort === 'heat') {
                results.sort((a, b) => b.h - a.h);
            } else {
                results.sort((a, b) => a.pw.zh.localeCompare(b.pw.zh, 'zh'));
            }

            renderKeywords(results);
        }

        function copyText(text) {
            navigator.clipboard.writeText(text).then(() => showToast('宸插鍒? ' + text));
        }

        function copyKeyword(zh, en) {
            const text = currentLang === 'en' ? en : zh;
            navigator.clipboard.writeText(text).then(() => showToast('宸插鍒? ' + text));
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2000);
        }

        document.getElementById('searchInput').addEventListener('input', performSearch);

        document.querySelectorAll('.lang-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentLang = btn.dataset.lang;
                performSearch();
            });
        });

        document.querySelectorAll('.filter-tag').forEach(tag => {
            tag.addEventListener('click', () => {
                document.querySelectorAll('.filter-tag').forEach(t => t.classList.remove('active'));
                tag.classList.add('active');
                currentFilter = tag.dataset.filter;
                performSearch();
            });
        });

        document.querySelectorAll('.sort-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentSort = btn.dataset.sort;
                performSearch();
            });
        });

        renderCategories();
        performSearch();


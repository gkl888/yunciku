        function luckyDraw() {
            const all = allKeywords;
            if (all.length < 3) return;
            const picked = [];
            const used = new Set();
            while (picked.length < 3) {
                const idx = Math.floor(Math.random() * all.length);
                if (!used.has(idx)) { used.add(idx); picked.push(all[idx]); }
            }
            const container = document.getElementById('luckyCards');
            container.innerHTML = '';
            picked.forEach(kw => {
                const card = document.createElement('div');
                card.className = 'lucky-card';
                const vwArr = (kw.vw && kw.vw.zh) ? kw.vw.zh : [];
                const awArr = (kw.aw && kw.aw.zh) ? kw.aw.zh : [];
                const swArr = (kw.sw && kw.sw.zh) ? kw.sw.zh : [];
                card.innerHTML = `
                    <div class="lucky-card-title">${kw.pw.zh}</div>
                    <div class="lucky-card-en">${kw.pw.en}</div>
                    ${vwArr.length ? '<div class="lucky-card-field"><strong>鍙樹綋:</strong>' + vwArr.slice(0,3).join('銆?) + '</div>' : ''}
                    ${awArr.length ? '<div class="lucky-card-field"><strong>灞炴€?</strong>' + awArr.slice(0,3).join('銆?) + '</div>' : ''}
                    ${swArr.length ? '<div class="lucky-card-field"><strong>鍦烘櫙:</strong>' + swArr.slice(0,3).join('銆?) + '</div>' : ''}
                    <div class="lucky-card-links">
                        <a href="https://s.1688.com/selloffer/offer_search.htm?keywords=${kw.pw_gbk}" target="_blank">1688</a>
                        <a href="https://www.alibaba.com/trade/search?SearchText=${encodeURIComponent(kw.pw.en)}" target="_blank">Alibaba</a>
                        <a href="https://www.made-in-china.com/products-search/hot-china-products/${encodeURIComponent(kw.pw.en)}.html" target="_blank">MIC</a>
                    </div>
                `;
                container.appendChild(card);
            });
            const quoteIdx = Math.floor(Math.random() * MOTIVATIONAL_QUOTES.length);
            const quote = MOTIVATIONAL_QUOTES[quoteIdx];
            const quoteCard = document.createElement('div');
            quoteCard.className = 'quote-card';
            quoteCard.innerHTML = `
                <div class="quote-icon">${quote.icon}</div>
                <div class="quote-text">${quote.text}</div>
                <div class="quote-author">-- 涓氬姟蹇冩硶</div>
            `;
            container.appendChild(quoteCard);
            container.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        const hotSearches = ['淇濋矞鐩?, '鏀剁撼', '鍘ㄦ埧', '鐑樼剻', '琛ｆ灦', '娓呮磥'];
        let hotIdx = 0;
        setInterval(() => {
            document.getElementById('searchInput').placeholder = '璇曡瘯鎼滅储: ' + hotSearches[hotIdx] + '...';
            hotIdx = (hotIdx + 1) % hotSearches.length;
        }, 3000);
    





// 杩戜竴骞撮噰璐褰曪紙鐙珛鏁版嵁锛?
let purchaseData = null;
let currentPurchaseCat = 'all';

// 鍔犺浇閲囪喘璁板綍鏁版嵁
async function loadPurchaseData() {
    if (purchaseData) return purchaseData;
    try {
        const resp = await fetch('purchase_history.json');
        purchaseData = await resp.json();
        return purchaseData;
    } catch(e) {
        console.error('鍔犺浇閲囪喘璁板綍澶辫触:', e);
        return null;
    }
}

// 鍒囨崲閲囪喘闈㈡澘
async function togglePurchasePanel(show) {
    const panel = document.getElementById('purchasePanel');
    const btn = document.getElementById('btnPurchaseHistory');
    if (show === undefined) show = !panel.classList.contains('show');
    
    if (show) {
        panel.classList.add('show');
        btn.classList.add('active');
        btn.style.background = 'linear-gradient(135deg,#059669,#10b981)';
        await renderPurchaseCats();
        renderPurchaseProducts('all');
        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
        panel.classList.remove('show');
        btn.classList.remove('active');
        btn.style.background = 'linear-gradient(135deg,#11998e,#38ef7d)';
    }
}

// 娓叉煋閲囪喘鍒嗙被瀵艰埅
async function renderPurchaseCats() {
    const data = await loadPurchaseData();
    if (!data) return;
    
    const nav = document.getElementById('purchaseCatsNav');
    document.getElementById('purchaseTotal').textContent = data.total + '涓骇鍝?;
    
    let html = '<button class="purchase-cat-btn active" onclick="renderPurchaseProducts(\'all\')">馃搵 鍏ㄩ儴</button>';
    for (const cat of data.categories) {
        html += `<button class="purchase-cat-btn" onclick="renderPurchaseProducts('${escId(cat.name)}')">${escHtml(cat.name)} <span class="purchase-cat-count">${cat.count}</span></button>`;
    }
    nav.innerHTML = html;
}

// 娓叉煋閲囪喘浜у搧鍒楄〃
async function renderPurchaseProducts(catName) {
    const data = await loadPurchaseData();
    if (!data) return;
    
    currentPurchaseCat = catName;
    
    // 鏇存柊鎸夐挳鐘舵€?
    document.querySelectorAll('.purchase-cat-btn').forEach(b => b.classList.remove('active'));
    event && event.target && event.target.classList.add('active');
    // 鍏煎娌℃湁 event 鐨勬儏鍐?
    if (!event) {
        document.querySelectorAll('.purchase-cat-btn').forEach(b => {
            if (b.textContent.includes(catName === 'all' ? '鍏ㄩ儴' : catName)) b.classList.add('active');
        });
    }
    
    // 鏀堕泦瑕佸睍绀虹殑浜у搧
    let products = [];
    let catLabel = '鍏ㄩ儴';
    if (catName === 'all') {
        for (const cat of data.categories) {
            for (const p of cat.products) {
                if (typeof p === 'string') {
                    products.push({ name_cn: p, name_en: '', category: cat.name });
                } else {
                    products.push({ name_cn: p.name_cn, name_en: p.name_en || '', category: cat.name });
                }
            }
        }
    } else {
        const cat = data.categories.find(c => escId(c.name) === catName);
        if (cat) {
            products = cat.products.map(p => {
                if (typeof p === 'string') return { name_cn: p, name_en: '', category: cat.name };
                return { name_cn: p.name_cn, name_en: p.name_en || '', category: cat.name };
            });
            catLabel = cat.name;
        }
    }
    
    // 鏇存柊淇℃伅鏍?
    document.getElementById('purchaseResultsInfo').innerHTML = 
        `褰撳墠鍒嗙被: <strong>${escHtml(catLabel)}</strong> | 鍏?<strong>${products.length}</strong> 涓骇鍝乣;
    
    // 娓叉煋浜у搧鍗＄墖
    const grid = document.getElementById('purchaseProductsGrid');
    grid.innerHTML = products.map(p => `
        <div class="purchase-product-card" title="${escHtml(p.category)}">
            <div style="font-weight:600;margin-bottom:4px;">${escHtml(p.name_cn || p.name)}</div>
            <div style="font-size:12px;color:#10b981;margin-bottom:2px;">${escHtml(p.name_en || '-')}</div>
            <div style="font-size:11px;color:#999;">${escHtml(p.category)}</div>
        </div>
    `).join('');
}

function escHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
}
function escId(s) {
    return s.replace(/[^\u4e00-\u9fa5a-zA-Z0-9]/g, '');
}

// 缁戝畾鎸夐挳浜嬩欢
document.getElementById('btnPurchaseHistory').addEventListener('click', function(e) {
    e.preventDefault();
    togglePurchasePanel();
});

    </script>

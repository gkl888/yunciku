<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>閲囪喘鐏垫劅寮曟搸 - Search Inspiration Engine</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 1200px; margin: 0 auto; }
        header { text-align: center; color: white; margin-bottom: 30px; }
        h1 { font-size: 2.5rem; margin-bottom: 10px; text-shadow: 2px 2px 4px rgba(0,0,0,0.2); }
        .subtitle { font-size: 1.1rem; opacity: 0.9; }
        .stats { display: flex; justify-content: center; gap: 30px; margin-top: 15px; }
        .stat-item { background: rgba(255,255,255,0.2); padding: 10px 20px; border-radius: 20px; backdrop-filter: blur(10px); }

        .search-box {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            margin-bottom: 25px;
        }
        .search-input-wrapper { display: flex; gap: 15px; margin-bottom: 15px; }
        .search-input {
            flex: 1;
            padding: 15px 25px;
            font-size: 18px;
            border: 2px solid #e0e0e0;
            border-radius: 50px;
            outline: none;
            transition: all 0.3s;
        }
        .search-input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 4px rgba(102,126,234,0.1);
        }
        .lang-toggle {
            display: flex;
            background: #f5f5f5;
            border-radius: 30px;
            overflow: hidden;
        }
        .lang-btn {
            padding: 12px 20px;
            border: none;
            background: transparent;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s;
        }
        .lang-btn.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .filters { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
        .filter-label { font-size: 13px; color: #666; margin-right: 5px; }
        .filter-tag {
            padding: 8px 16px;
            background: #f0f0f0;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.3s;
        }
        .filter-tag:hover, .filter-tag.active {
            background: #667eea;
            color: white;
        }

        .sort-options {
            display: flex;
            gap: 10px;
            margin-left: auto;
        }
        .sort-btn {
            padding: 8px 16px;
            background: transparent;
            border: 2px solid #ddd;
            border-radius: 20px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.3s;
        }
        .sort-btn:hover, .sort-btn.active {
            border-color: #667eea;
            background: #667eea;
            color: white;
        }

        .categories-nav {
            background: white;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .categories-title {
            font-size: 14px;
            color: #666;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: 10px;
        }
        .category-card {
            padding: 12px;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            text-align: center;
        }
        .category-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }
        .category-card.selected {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .category-name { font-weight: 600; font-size: 13px; }
        .category-count { font-size: 11px; opacity: 0.7; margin-top: 5px; }

        .results-info { color: white; margin-bottom: 15px; font-size: 14px; }
        .results-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 20px;
        }
        .keyword-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        .keyword-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            transition: all 0.3s;
        }
        .keyword-card.heat-5::before { background: linear-gradient(90deg, #ff416c, #ff4b2b); }
        .keyword-card.heat-4::before { background: linear-gradient(90deg, #f093fb, #f5576c); }
        .keyword-card.heat-3::before { background: linear-gradient(90deg, #667eea, #764ba2); }
        .keyword-card.heat-2::before { background: linear-gradient(90deg, #4facfe, #00f2fe); }
        .keyword-card.heat-1::before { background: linear-gradient(90deg, #a8edea, #fed6e3); }

        .keyword-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }
        .keyword-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
            position: relative;
        }
        .keyword-title-group {
            flex: 1;
        }
        .keyword-actions {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .keyword-title { font-size: 20px; font-weight: 700; color: #333; }
        .keyword-title-en { font-size: 13px; color: #666; margin-top: 4px; }
        .heat-badge {
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 5px 12px;
            border-radius: 15px;
            font-size: 12px;
            font-weight: 600;
            color: white;
        }
        .heat-5 .heat-badge { background: linear-gradient(135deg, #ff416c, #ff4b2b); }
        .heat-4 .heat-badge { background: linear-gradient(135deg, #f093fb, #f5576c); }
        .heat-3 .heat-badge { background: linear-gradient(135deg, #667eea, #764ba2); }
        .heat-2 .heat-badge { background: linear-gradient(135deg, #4facfe, #00f2fe); }
        .heat-1 .heat-badge { background: linear-gradient(135deg, #a8edea, #fed6e3); color: #666; }

        .keyword-section { margin-bottom: 10px; }
        .section-title {
            font-size: 11px;
            color: #999;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .word-tags { display: flex; flex-wrap: wrap; gap: 5px; }
        .word-tag {
            padding: 3px 10px;
            background: #f0f0f0;
            border-radius: 10px;
            font-size: 11px;
            color: #555;
            cursor: pointer;
            transition: all 0.2s;
        }
        .word-tag:hover {
            background: #667eea;
            color: white;
        }

        .platform-links { display: flex; gap: 6px; margin-top: 12px; }
        .platform-btn {
            flex: 1;
            padding: 8px;
            border: none;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            text-align: center;
            color: white;
        }
        .platform-1688 { background: #ff6a00; }
        .platform-alibaba { background: #ff6b00; }
        .platform-mic { background: #e74c3c; }
        .platform-btn:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }

        .keyword-note {
            margin-top: 10px;
            padding: 8px;
            background: #fff8e1;
            border-radius: 6px;
            font-size: 11px;
            color: #666;
            border-left: 3px solid #ffa726;
        }

        .no-results {
            text-align: center;
            padding: 60px 20px;
            color: white;
        }
        .no-results h2 { font-size: 24px; margin-bottom: 10px; }
        .no-results p { opacity: 0.8; }

        .copy-btn {
            background: rgba(0,0,0,0.05);
            border: none;
            padding: 5px 10px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 11px;
            transition: all 0.3s;
            white-space: nowrap;
        }
        .copy-btn:hover { background: rgba(0,0,0,0.1); }


        /* 閲囪喘璁板綍鏍峰紡 */
        .purchase-history-panel {
            display: none;
            background: white;
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 25px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            animation: slideDown 0.3s ease-out;
        }
        .purchase-history-panel.show { display: block; }
        .purchase-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .purchase-title {
            font-size: 18px;
            font-weight: 700;
            color: #11998e;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .purchase-stat-item strong { color: #059669; }
        .purchase-item:hover { background: #f0fdf4; }
        .purchase-empty-icon { font-size: 48px; margin-bottom: 10px; }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            color: white;
            padding: 12px 24px;
            border-radius: 30px;
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 1000;
        }
        .toast.show { opacity: 1; }

        .heat-legend {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 10px;
            font-size: 12px;
            color: rgba(255,255,255,0.9);
        }
        .heat-item { display: flex; align-items: center; gap: 5px; }
        .heat-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }
        .heat-dot-5 { background: linear-gradient(135deg, #ff416c, #ff4b2b); }
        .heat-dot-4 { background: linear-gradient(135deg, #f093fb, #f5576c); }
        .heat-dot-3 { background: linear-gradient(135deg, #667eea, #764ba2); }
        .heat-dot-2 { background: linear-gradient(135deg, #4facfe, #00f2fe); }
        .heat-dot-1 { background: linear-gradient(135deg, #a8edea, #fed6e3); }

        @media (max-width: 768px) {
            h1 { font-size: 1.8rem; }
            .search-input-wrapper { flex-direction: column; }
            .results-grid { grid-template-columns: 1fr; }
            .categories-grid { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); }
            .filters { flex-direction: column; align-items: flex-start; }
            .sort-options { margin-left: 0; margin-top: 10px; }
            .heat-legend { flex-wrap: wrap; gap: 10px; }
        }
        .lucky-draw-section {
            text-align: center;
            padding: 30px 20px;
            margin: 20px 0;
            background: linear-gradient(135deg, #ff6b9d 0%, #ff8a56 40%, #ffc837 100%);
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(255,107,157,0.3);
        }
        .lucky-draw-title {
            font-size: 1.4em;
            font-weight: 800;
            color: #fff;
            margin-bottom: 16px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }
        .lucky-draw-btn {
            background: #fff;
            color: #ff6b9d;
            border: none;
            padding: 14px 36px;
            border-radius: 50px;
            font-size: 1.1em;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(0,0,0,0.12);
            transition: all 0.3s ease;
        }
        .lucky-draw-btn:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: 0 6px 24px rgba(0,0,0,0.18);
        }
        .lucky-cards {
            display: flex;
            gap: 16px;
            margin-top: 24px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .lucky-card {
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            width: 240px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            animation: cardFlipIn 0.6s ease-out both;
            text-align: left;
        }
        .lucky-card:nth-child(1) { animation-delay: 0s; }
        .lucky-card:nth-child(2) { animation-delay: 0.15s; }
        .lucky-card:nth-child(3) { animation-delay: 0.3s; }
        .lucky-card:nth-child(4) { animation-delay: 0.45s; }
        .quote-card {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            border-radius: 16px;
            padding: 24px 20px;
            width: 240px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            animation: cardFlipIn 0.6s ease-out both;
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        .quote-card::before {
            content: '馃挕';
            font-size: 2em;
            position: absolute;
            top: 10px;
            right: 10px;
            opacity: 0.3;
        }
        .quote-card .quote-text {
            font-size: 1.1em;
            font-weight: 700;
            color: #fff;
            line-height: 1.6;
            margin-bottom: 12px;
            text-shadow: 0 1px 4px rgba(0,0,0,0.3);
        }
        .quote-card .quote-author {
            font-size: 0.85em;
            color: rgba(255,255,255,0.6);
            font-style: italic;
        }
        .quote-card .quote-icon {
            font-size: 1.5em;
            margin-bottom: 8px;
        }
        @keyframes cardFlipIn {
            0% { transform: rotateY(90deg) scale(0.8); opacity: 0; }
            100% { transform: rotateY(0deg) scale(1); opacity: 1; }
        }
        .lucky-card-title {
            font-size: 1.3em;
            font-weight: 700;
            color: #333;
            margin-bottom: 8px;
        }
        .lucky-card-en {
            font-size: 0.85em;
            color: #999;
            margin-bottom: 10px;
        }
        .lucky-card-field {
            font-size: 0.82em;
            color: #666;
            margin-bottom: 4px;
        }
        .lucky-card-field strong { color: #ff6b9d; }
        .lucky-card-links {
            margin-top: 10px;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        .lucky-card-links a {
            background: linear-gradient(135deg, #ff6b9d, #ffc837);
            color: #fff;
            padding: 4px 10px;
            border-radius: 12px;
            text-decoration: none;
            font-size: 0.78em;
            font-weight: 600;
            transition: transform 0.2s;
        }
        .lucky-card-links a:hover { transform: scale(1.08); }
        @media (max-width: 768px) {
            .lucky-cards { flex-direction: column; align-items: center; }
            .lucky-card { width: 90%; max-width: 320px; }
        }
    
        /* 杩戜竴骞撮噰璐褰?- 鐙珛鏉垮潡 */
        .purchase-history-panel {
            display: none;
            background: white;
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 25px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            animation: slideDown 0.3s ease-out;
        }
        .purchase-history-panel.show { display: block; }
        .purchase-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .purchase-title {
            font-size: 22px;
            font-weight: 800;
            color: #11998e;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .purchase-total-badge {
            background: linear-gradient(135deg,#11998e,#38ef7d);
            color: white;
            font-size: 13px;
            padding: 4px 14px;
            border-radius: 20px;
            font-weight: 700;
        }
        .purchase-close-btn {
            padding: 8px 20px;
            background: #6b7280;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 14px;
            cursor: pointer;
        }
        .purchase-close-btn:hover { filter: brightness(1.1); }
        
        /* 閲囪喘鍒嗙被瀵艰埅 */
        .purchase-cats-nav {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 20px;
            padding: 15px;
            background: #f0fdf4;
            border-radius: 16px;
        }
        .purchase-cat-btn {
            padding: 8px 16px;
            background: white;
            border: 2px solid #d1fae5;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 600;
            color: #065f46;
            cursor: pointer;
            transition: all 0.2s;
        }
        .purchase-cat-btn:hover { border-color: #10b981; background: #ecfdf5; }
        .purchase-cat-btn.active {
            background: linear-gradient(135deg,#11998e,#38ef7d);
            color: white;
            border-color: transparent;
        }
        .purchase-cat-count {
            font-size: 11px;
            opacity: 0.8;
            margin-left: 4px;
        }
        
        /* 閲囪喘浜у搧灞曠ず */
        .purchase-results-info {
            font-size: 14px;
            color: #666;
            margin-bottom: 15px;
            padding: 10px 15px;
            background: #f9fafb;
            border-radius: 12px;
        }
        .purchase-products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 12px;
        }
        .purchase-product-card {
            background: #f9fafb;
            border-radius: 12px;
            padding: 14px 16px;
            font-size: 14px;
            color: #333;
            border-left: 4px solid #10b981;
            transition: all 0.2s;
            cursor: default;
        }
        .purchase-product-card:hover {
            background: #ecfdf5;
            transform: translateX(4px);
            box-shadow: 0 4px 12px rgba(16,185,129,0.15);
        }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @media (max-width: 768px) {
            .purchase-products-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
            .purchase-cats-nav { gap: 6px; }
            .purchase-cat-btn { font-size: 12px; padding: 6px 12px; }
        }

